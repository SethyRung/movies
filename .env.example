# Docker
POSTGRES_USER=admin
POSTGRES_PASSWORD=supersecret
POSTGRES_DB=moviedb

# Database
DATABASE_DRIVER=postgres-js
DATABASE_URL=postgresql://admin:supersecret@localhost:5432/moviedb

# JWT Access Token
NUXT_JWT_ACCESS_SECRET=your-access-secret-key-change-in-production
NUXT_JWT_ACCESS_EXPIRES_IN=15m

# JWT Refresh Token
NUXT_JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
NUXT_JWT_REFRESH_EXPIRES_IN=7d
